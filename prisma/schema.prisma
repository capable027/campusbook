generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum BookStatus {
  DRAFT
  PENDING_REVIEW
  ON_SALE
  REJECTED
  SOLD_OFF
  REMOVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  studentId    String?  @unique
  passwordHash String
  role         UserRole @default(USER)
  major        String?
  grade        String?
  banned       Boolean  @default(false)
  bannedReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  booksListed  Book[]   @relation("SellerBooks")
  ordersBuyer  Order[]  @relation("BuyerOrders")
  ordersSeller Order[]  @relation("SellerOrders")

  conversationsBuyer  Conversation[] @relation("ConvBuyer")
  conversationsSeller Conversation[] @relation("ConvSeller")
  messagesSent        Message[]      @relation("MessageSender")

  reviewsGiven    Review[] @relation("ReviewGiver")
  reviewsReceived Review[] @relation("ReviewReceiver")
}

model Book {
  id          String     @id @default(cuid())
  title       String
  author      String
  isbn        String?
  price       Decimal    @db.Decimal(10, 2)
  condition   String
  description String     @db.Text
  images      Json       @default("[]")
  major       String?
  course      String?
  status      BookStatus @default(PENDING_REVIEW)
  reviewNote  String?
  sellerId    String
  seller      User       @relation("SellerBooks", fields: [sellerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders        Order[]
  conversations Conversation[]

  @@index([status])
  @@index([major])
  @@index([createdAt])
}

model Order {
  id       String      @id @default(cuid())
  buyerId  String
  sellerId String
  bookId   String
  status   OrderStatus @default(PENDING)
  note     String?

  buyer  User @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  seller User @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Cascade)
  book   Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review Review?

  @@index([bookId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

model Conversation {
  id            String   @id @default(cuid())
  bookId        String
  buyerId       String
  sellerId      String
  lastMessageAt DateTime @default(now())

  book   Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  buyer  User @relation("ConvBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller User @relation("ConvSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  messages Message[]

  @@unique([bookId, buyerId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model Review {
  id         String   @id @default(cuid())
  orderId    String   @unique
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewer User  @relation("ReviewGiver", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User  @relation("ReviewReceiver", fields: [revieweeId], references: [id], onDelete: Cascade)
}
