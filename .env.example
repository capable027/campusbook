# PostgreSQL
# Docker (docker compose): postgres user + password match docker-compose.yml
# Homebrew / native install: there is often no `postgres` role — use your superuser OS name, e.g. postgresql://you@localhost:5432/campusbook?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/campusbook?schema=public"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
AUTH_URL="http://localhost:3000"

# 图片存储（默认 local，可省略）
# STORAGE_DRIVER=local
#
# S3 或 R2 示例：
# STORAGE_DRIVER=s3
# S3_BUCKET=my-bucket
# ASSET_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
# AWS_REGION=auto
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE=true
#
# Vercel Blob：
# STORAGE_DRIVER=vercel-blob
# BLOB_READ_WRITE_TOKEN=
#
# next/image 远程图（可选，与 ASSET_PUBLIC_BASE_URL 同源时可不单独设）
# STORAGE_IMAGE_HOST=
